# ─── Database ───────────────────────────────────────────────
# SQLite (default for local dev — file lives at ./prisma/jalsa.db)
DATABASE_URL="file:./jalsa.db"

# PostgreSQL (switch for production — comment out SQLite above)
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/jalsa_resort"

# ─── Server ─────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── JWT ────────────────────────────────────────────────────
# Generate a long random string: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ─── Email (Nodemailer) ──────────────────────────────────────
# For Gmail: enable "App Passwords" in your Google account
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password

# ─── Business config ─────────────────────────────────────────
ADMIN_EMAIL=admin@jalsaresort.com
RESORT_NAME="Jalsa Hotel & Resort"
RESORT_PHONE="+91 90390 10830"

# ─── CORS ────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500,http://127.0.0.1:5500

# ─── Admin defaults (change immediately after first run) ─────
ADMIN_DEFAULT_EMAIL=admin@jalsaresort.com
ADMIN_DEFAULT_PASSWORD=Admin@Jalsa2024
